{
  "name": "mcp-server-usdd-test",
  "version": "1.1.7",
  "description": "MCP server for the USDD protocol across TRON, Ethereum, and BSC. Supports vaults, PSM swaps, USDD Savings, protocol monitoring, and AI-guided risk workflows.",
  "type": "module",
  "module": "src/index.ts",
  "main": "build/index.js",
  "bin": {
    "mcp-server-usdd-test": "./bin/cli.js"
  },
  "files": [
    "build/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start:http": "tsx src/server/http-server.ts",
    "dev:http": "tsx watch src/server/http-server.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@bankofai/agent-wallet": "^2.3.1",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "tronlink-signer": "0.1.1",
    "tronweb": "^6.1.1",
    "viem": "^2.37.5",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tron",
    "ethereum",
    "bsc",
    "usdd",
    "defi",
    "stablecoin",
    "vault",
    "makerdao",
    "ai",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decentralized-usd/mcp-server-usdd.git"
  },
  "homepage": "https://github.com/decentralized-usd/mcp-server-usdd#readme",
  "bugs": {
    "url": "https://github.com/decentralized-usd/mcp-server-usdd/issues"
  },
  "license": "MIT"
}
